# .mas/ — runtime artifacts (MCP server code is intentionally tracked, but logs/state not)
.mas/mcp/node_modules/
.mas/dashboards/
.mas/scheduler.log
.mas/scheduler.sh
.mas/*.pid
.mas/*.log
.mas/autostart.sh
.mas/dashboard-daemon.sh
.mas/live-*
**/.mas/dashboards/
**/.mas/scheduler.sh
**/.mas/*.log
**/.mas/*.pid

