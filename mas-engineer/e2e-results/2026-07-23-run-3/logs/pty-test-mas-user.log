data["agent_health"]["sub_mas-agent-guardian"]["total_calls"] = data["agent_health"]["sub_mas-agent-guardian"].get("total_calls", 0) + 1

with open('/workspace/mas-engineer-src/mas-engineer/.state/guardian.yaml', 'w') as f:
    yaml.dump(data, f, default_flow_style=False, allow_unicode=True, sort_keys=False)

