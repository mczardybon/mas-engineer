import yaml
from datetime import datetime, timezone

now = datetime.now(timezone.utc).isoformat()

with open('/workspace/mas-engineer-src/mas-engineer/.state/guardian.yaml') as f:
    data = yaml.safe_load(f)

# Add delegation history entry
entry = {
    "agent": "sub_mas-agent-guardian",
    "task": "HEALTH_REPORT",
    "status": "success",
    "action": "none",
    "detail": "Full agent health check — all 54 agents healthy, 0 dead, 0 degraded, 0 drifts. Anomalies: 13× clone agent creation loop, 2× e2e team test failures (sales/medium timeout 603s, marketing/hard timeout 83s)",
    "timestamp": now
}
data.setdefault("delegation_history", []).append(entry)

# Update meta
data["meta"]["last_update"] = now

# Update summary
data["summary"]["total_agents"] = 54
data["summary"]["healthy"] = 54
data["summary"]["degraded"] = 0
data["summary"]["dead"] = 0
data["summary"]["death_risks"] = 0
data["summary"]["loop_risks"] = 1  # clone loop
data["summary"]["schema_issues"] = 0
data["summary"]["semantic_issues"] = 0
data["summary"]["overall_health_score"] = 100

# Update guardian's own health
