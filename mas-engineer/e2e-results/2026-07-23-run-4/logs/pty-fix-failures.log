    "translator": "/root/.config/goose/recipes/translator/translator-team.yaml",
    "sales":      "/root/.config/goose/recipes/sales/sales-team.yaml",
    "marketing":  "/root/.config/goose/recipes/marketing/marketing-team.yaml",
