import hashlib, os, subprocess
def h():
    files = {}
    for d in ['.state', 'recipe', 'template/recovery']:
        if not os.path.exists(d): continue
        for r, _, fs in os.walk(d):
            if '.git' in r or 'workflow_runs' in r: continue
            for f in fs:
                p = os.path.join(r, f)
                try: files[os.path.relpath(p, '.')] = hashlib.md5(open(p,'rb').read()).hexdigest()
                except: pass
    files['mas-engineer_active'] = str(os.path.exists('mas-engineer_active'))
    return files
before = h()
for wf in ['wf_recovery_checkpoint', 'wf_recovery_safezone', 'wf_recovery_timeline', 'wf_recovery_defib']:
    subprocess.run(['python3', 'tools/dev_workflow_runner.py', wf], capture_output=True, timeout=120)
after = h()
added = set(after) - set(before)
removed = set(before) - set(after)
changed = [k for k in before if k in after and before[k] != after[k]]
assert not (added or removed or changed), f'changes: {added=} {removed=} {changed=}'
print('T3 PASS')
PY
