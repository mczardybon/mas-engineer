import ast

path = '/workspace/team1/vulnerable_app.py'
with open(path) as f:
    source = f.read()

tree = ast.parse(source)

# Full AST dump
print('=== AST STRUCTURE ===')
for node in ast.walk(tree):
    if isinstance(node, ast.FunctionDef):
        print(f'Function: {node.name} (line {node.lineno}-{node.end_lineno})')
        for arg in node.args.args:
            print(f'  param: {arg.arg}')
        for child in ast.walk(node):
            if isinstance(child, ast.Call):
                for kw in child.keywords:
                    pass  # not needed
                if hasattr(child.func, 'attr'):
                    print(f'  calls: {child.func.attr}')
                elif hasattr(child.func, 'id'):
                    print(f'  calls: {child.func.id}')
    elif isinstance(node, ast.Import):
        print(f'Import: (line {node.lineno})')
        for alias in node.names:
            print(f'  module: {alias.name} (as={alias.asname})')
    elif isinstance(node, ast.Assign):
        for target in node.targets:
            if hasattr(target, 'id'):
                print(f'Assign: {target.id} (line {node.lineno})')

# Find unused imports
print()
print('=== UNUSED IMPORTS ANALYSIS ===')
import_names = set()
used_names = set()
for node in ast.walk(tree):
    if isinstance(node, ast.Import):
        for alias in node.names:
            name = alias.asname if alias.asname else alias.name
            import_names.add(name)
    elif isinstance(node, ast.Attribute):
        if isinstance(node.value, ast.Name):
            used_names.add(node.value.id)
    elif isinstance(node, ast.Name):
        used_names.add(node.id)

for imp in import_names:
    if imp not in used_names:
        print(f'POSSIBLY UNUSED: {imp}')

# Check for bare except
print()
print('=== BARE EXCEPT CHECK ===')
for node in ast.walk(tree):
    if isinstance(node, ast.ExceptHandler):
        if node.type is None:
            print(f'BARE EXCEPT at line {node.lineno}')
        else:
            if hasattr(node.type, 'id'):
                print(f'Named except: {node.type.id} at line {node.lineno}')

# Count complexity (functions with >1 branch)
print()
print('=== COMPLEXITY ===')
for node in ast.walk(tree):
    if isinstance(node, ast.FunctionDef):
        branch_count = 0
        for child in ast.walk(node):
            if isinstance(child, (ast.If, ast.While, ast.For, ast.ExceptHandler)):
                branch_count += 1
        print(f'{node.name}: {len(node.body)} statements, {branch_count} branches')

# Line length check
print()
print('=== LINES > 100 chars ===')
for i, line in enumerate(source.split('\n'), 1):
    if len(line) > 100:
        print(f'Line {i}: {len(line)} chars - {line.strip()[:80]}...')
"


