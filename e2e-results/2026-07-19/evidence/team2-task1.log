print(f"D3 Outliers: outlier_rate={outlier_rate:.4f}, deduction={outlier_deduction:.2f}, score={score:.2f}")

# Dimension 4: Missing values severity — weight: 15%
high_missing_columns = 0
total_columns = 0
for f_name, f_data in merged.items():
