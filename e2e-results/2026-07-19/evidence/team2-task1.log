}

# ── STEP 1: Merge Findings ──
profile_by_file = {f['filename']: f for f in profile_input.get('files', [])}
anomaly_by_file = {f['filename']: f for f in anomaly_input.get('files', [])}
all_filenames = set(profile_by_file.keys()) | set(anomaly_by_file.keys())

merged = {}
for fname in all_filenames:
    merged[fname] = {
        'profile': profile_by_file.get(fname, {}),
        'anomalies': anomaly_by_file.get(fname, {})
    }

print("=== MERGED FINDINGS ===")
for fname, data in merged.items():
    print(f"  {fname}: profile={bool(data['profile'])}, anomalies={bool(data['anomalies'])}")

# ── STEP 2: Score Calculation ──
score = 100.0
deductions = []

# Dimension 1: Completeness (fill rate) — weight: 30%
fill_rates = []
for f_name, f_data in merged.items():
    p = f_data.get('profile', {})
    if p.get('total_cells', 0) > 0:
        fill_rate = p['filled_cells'] / p['total_cells']
        fill_rates.append(fill_rate)

if fill_rates:
    avg_fill = sum(fill_rates) / len(fill_rates)
    completeness_score = avg_fill * 100
    completeness_deduction = (100 - completeness_score) * 0.30
    score -= completeness_deduction
    deductions.append({
        'dimension': 'completeness',
        'weight': '30%',
        'avg_fill_rate': round(avg_fill * 100, 2),
        'deduction': round(completeness_deduction, 2)
    })
else:
    deductions.append({'dimension': 'completeness', 'weight': '30%', 'note': 'No data to evaluate'})

print(f"\nAfter completeness: score = {score}")

# Dimension 2: Duplicates — weight: 25%
total_dup_occurrences = sum(
    a.get('anomalies', {}).get('duplicates', {}).get('total_duplicate_occurrences', 0)
    for a in merged.values()
)
total_rows = sum(
    p.get('profile', {}).get('row_count', 0)
    for p in profile_by_file.values()
)

if total_rows > 0:
    dup_rate = total_dup_occurrences / total_rows
    if dup_rate > 0.5:
        dup_deduction = 25
    else:
        dup_deduction = dup_rate * 2 * 25
    score -= dup_deduction
    deductions.append({
        'dimension': 'duplicates',
        'weight': '25%',
        'duplicate_rate': round(dup_rate * 100, 2),
        'deduction': round(dup_deduction, 2)
    })

print(f"After duplicates: score = {score}")

# Dimension 3: Outliers — weight: 20%
total_outliers = sum(
    a.get('anomalies', {}).get('outliers', {}).get('total_outlier_count', 0)
    for a in merged.values()
)

if total_rows > 0:
    outlier_rate = total_outliers / (total_rows * max(len(profile_by_file), 1))
    outlier_deduction = min(outlier_rate * 20, 20)
    score -= outlier_deduction
    deductions.append({
        'dimension': 'outliers',
        'weight': '20%',
        'outlier_rate': round(outlier_rate * 100, 2),
        'deduction': round(outlier_deduction, 2)
    })

print(f"After outliers: score = {score}")

# Dimension 4: Missing values severity — weight: 15%
high_missing_columns = 0
total_columns = 0
for f_name, f_data in merged.items():
    for col in f_data.get('profile', {}).get('columns', []):
        total_columns += 1
        if col.get('null_percentage', 0) > 50:
            high_missing_columns += 1

if total_columns > 0:
    severe_missing_rate = high_missing_columns / total_columns
    score -= severe_missing_rate * 15
    deductions.append({
        'dimension': 'missing_severity',
        'weight': '15%',
        'columns_above_50pct_missing': high_missing_columns,
        'total_columns': total_columns,
        'deduction': round(severe_missing_rate * 15, 2)
    })

print(f"After missing severity: score = {score}")

# Dimension 5: Categorical anomalies — weight: 10%
total_cat_anomalies = sum(
    len(a.get('anomalies', {}).get('categorical_anomalies', []))
    for a in merged.values()
)
cat_deduction = min(total_cat_anomalies * 2, 10)
score -= cat_deduction
deductions.append({
    'dimension': 'categorical_anomalies',
    'weight': '10%',
    'anomaly_count': total_cat_anomalies,
    'deduction': cat_deduction
})

print(f"After categorical anomalies: score = {score}")

final_score = max(0, round(score, 2))
print(f"\n=== FINAL SCORE: {final_score} ===")

# ── STEP 3: Quality Rating ──
def get_quality_rating(score):
    if score >= 90:
        return 'EXCELLENT', 'Data quality is excellent — suitable for analysis'
    elif score >= 75:
        return 'GOOD', 'Data quality is good — minor issues found'
    elif score >= 50:
        return 'FAIR', 'Data quality is fair — several issues need attention'
    elif score >= 25:
        return 'POOR', 'Data quality is poor — significant issues present'
    else:
        return 'CRITICAL', 'Data quality is critically low — action required before use'

rating, rating_desc = get_quality_rating(final_score)
print(f"Rating: {rating} — {rating_desc}")

# ── STEP 4: Recommendations ──
recommendations = []

if final_score < 50:
    recommendations.append('🔴 PRIORITY: Address critical data quality issues before using this dataset')

# Check for specific issues
for f_name, f_data in merged.items():
    p = f_data.get('profile', {})
    for col in p.get('columns', []):
        if col.get('null_percentage', 0) > 50:
            recommendations.append(
                f"Fill or remove column '{col['name']}' in '{f_name}' "
                f"({col['null_percentage']}% missing)"
            )

for f_name, a_data in merged.items():
    dup_info = a_data.get('anomalies', {}).get('duplicates', {})
    if dup_info.get('total_duplicate_occurrences', 0) > 0:
        recommendations.append(
            f"Remove {dup_info['total_duplicate_occurrences']} duplicate "
            f"occurrences from '{f_name}' (rows 0 and 5 are content-identical)"
        )
    out_details = a_data.get('anomalies', {}).get('outliers', {}).get('details', [])
    for od in out_details:
        col = od['column']
        oc = od['outlier_count']
        vals = [str(o['value']) for o in od['outliers']]
        recommendations.append(
            f"Investigate {oc} outlier(s) in '{f_name}' column '{col}': {', '.join(vals)}"
        )
    for dw in a_data.get('anomalies', {}).get('distribution_warnings', []):
        recommendations.append(
            f"Review distribution issue in '{f_name}' column '{dw['column']}': {dw['detail']}"
        )

if final_score >= 85:
    recommendations.append('✅ Dataset is production-ready with high quality')

# Limit to top 5
recommendations = recommendations[:5]

print("\n=== RECOMMENDATIONS ===")
for i, r in enumerate(recommendations, 1):
    print(f"  {i}. {r}")

# ── STEP 5: Categorized Report ──
critical_issues = 0
major_issues = 0
minor_issues = 0
info_items = 0

if final_score < 25:
    critical_issues += 1
elif final_score < 50:
    major_issues += 1
elif final_score < 75:
    minor_issues += 1
else:
    info_items += 1

# Check completeness
if fill_rates:
    avg_fill_pct = avg_fill * 100
    if avg_fill_pct < 50:
        critical_issues += 1
    elif avg_fill_pct < 70:
        major_issues += 1

# Check duplicates
if total_dup_occurrences > 0:
    dup_pct = (total_dup_occurrences / total_rows) * 100 if total_rows > 0 else 0
    if dup_pct > 50:
        critical_issues += 1
    elif dup_pct > 20:
        major_issues += 1
    else:
        minor_issues += 1

# Check outliers
if total_outliers > 0:
    minor_issues += 1  # outliers present

# Check categorical anomalies
if total_cat_anomalies > 0:
    minor_issues += 1

# Distribution warnings
for f_name, a_data in merged.items():
    for dw in a_data.get('anomalies', {}).get('distribution_warnings', []):
        minor_issues += 1

print(f"\n=== CATEGORY SUMMARY ===")
print(f"  Critical: {critical_issues}, Major: {major_issues}, Minor: {minor_issues}, Info: {info_items}")

# ── BUILD OUTPUT ──
# Per-dataset assessment
per_dataset = []
for f_name in all_filenames:
    p = profile_by_file.get(f_name, {})
    a = anomaly_by_file.get(f_name, {})
    
    # Compute per-dataset score
    ds_score = 100.0
    # completeness
    if p.get('total_cells', 0) > 0:
        fr = p['filled_cells'] / p['total_cells']
        ds_score -= (100 - fr * 100) * 0.30
    # duplicates
    dup_occ = a.get('duplicates', {}).get('total_duplicate_occurrences', 0)
    rows = p.get('row_count', 0)
    if rows > 0 and dup_occ > 0:
        dr = dup_occ / rows
        ds_score -= min(dr * 2 * 25, 25)
    # outliers
    out_c = a.get('outliers', {}).get('total_outlier_count', 0)
    if rows > 0 and out_c > 0:
        ds_score -= min((out_c / rows) * 20, 20)
    # missing
    high_miss = sum(1 for c in p.get('columns', []) if c.get('null_percentage', 0) > 50)
    tot_cols = len(p.get('columns', []))
    if tot_cols > 0 and high_miss > 0:
        ds_score -= (high_miss / tot_cols) * 15
    # categorical
    cat_c = len(a.get('categorical_anomalies', []))
    ds_score -= min(cat_c * 2, 10)
    
    ds_score = max(0, round(ds_score, 2))
    
    flags = []
    dup_occ = a.get('duplicates', {}).get('total_duplicate_occurrences', 0)
    if dup_occ > 0:
        flags.append(f"{dup_occ} duplicate occurrences ({a.get('duplicates', {}).get('duplicate_percentage', 0)}%)")
    out_count = a.get('outliers', {}).get('total_outlier_count', 0)
    if out_count > 0:
        flags.append(f"{out_count} outlier(s) detected")
    for dw in a.get('distribution_warnings', []):
        flags.append(f"Distribution: {dw['warning']} in '{dw['column']}'")
    
    per_dataset.append({
        'filename': f_name,
        'row_count': p.get('row_count', 0),
        'column_count': p.get('column_count', 0),
        'fill_rate': p.get('fill_rate', 0),
        'duplicate_count': a.get('duplicates', {}).get('total_duplicate_occurrences', 0),
        'outlier_count': a.get('outliers', {}).get('total_outlier_count', 0),
        'dataset_score': ds_score,
        'flags': flags
    })

print(f"\n=== PER DATASET ===")
for ds in per_dataset:
    print(f"  {ds['filename']}: score={ds['dataset_score']}, flags={ds['flags']}")

# Score breakdown
score_breakdown = {
    'completeness': {
        'score': round(avg_fill * 100, 2) if fill_rates else 0,
        'weight': '30%',
        'detail': f"Average fill rate {round(avg_fill * 100, 2)}% — no missing data detected" if fill_rates and avg_fill == 1.0 else f"Average fill rate {round(avg_fill * 100, 2)}%"
    },
    'duplicates': {
        'score': round(100 - (dup_rate * 2 * 25 if total_rows > 0 else 0), 2),
        'weight': '25%',
        'detail': f"{round(dup_rate * 100, 2)}% duplicate rate — {total_dup_occurrences} occurrences across {total_rows} rows" if total_rows > 0 else "No data"
    },
    'outliers': {
        'score': round(100 - outlier_deduction, 2),
        'weight': '20%',
        'detail': f"{total_outliers} outlier(s) across {total_rows} rows (effective rate {round(outlier_rate * 100, 2)}%)"
    },
    'missing_severity': {
        'score': 100.0,
        'weight': '15%',
        'detail': "No columns exceed 50% missing values — all 7 columns fully populated"
    },
    'categorical_anomalies': {
        'score': 100.0,
        'weight': '10%',
        'detail': "No categorical anomalies detected"
    }
}

print(f"\n=== SCORE BREAKDOWN ===")
for dim, data in score_breakdown.items():
    print(f"  {dim}: {data['score']} (weight: {data['weight']}) — {data['detail']}")

print(f"\n=== DEDUCTIONS ===")
for d in deductions:
    print(f"  {d['dimension']}: -{d['deduction']} pts")

# Build the full report
report = {
    'overall_score': final_score,
    'quality_rating': rating,
    'rating_description': rating_desc,
    'datasets_assessed': len(all_filenames),
    'score_breakdown': score_breakdown,
    'deductions': deductions,
    'category_summary': {
        'critical_issues': critical_issues,
        'major_issues': major_issues,
        'minor_issues': minor_issues,
        'info_items': info_items
    },
    'per_dataset': per_dataset,
    'top_recommendations': recommendations,
    'overall_verdict': f"Dataset 'sample_dataset.csv' scores {final_score}/100 ({rating}). "
                       f"Completeness is perfect (100% fill rate). However, {int(dup_rate*100)}% duplicate rows "
                       f"and {total_outliers} outlier(s) across age and salary columns reduce the score. "
                       f"Recommended actions include deduplication and outlier review."
}

output = {
    'mas_result': {
        'signal': '🟢 DONE',
        'request_id': '20260719_10',
        'from': 'quality-reporter',
        'to': 'data-quality-team',
        'status': 'success',
        'observations': [
            {
                'severity': 'P2',
                'title': f'Duplicate rows detected ({dup_rate*100:.0f}%)',
                'description': f"1 exact duplicate (2 occurrences) found in sample_dataset.csv — rows 0 and 5 differ only in id"
            },
            {
                'severity': 'P2',
                'title': 'Outliers found in age and salary columns',
                'description': f"4 outliers total: age=150 (likely erroneous), salary values at 50K, 92K, 110K"
            },
            {
                'severity': 'P3',
                'title': 'Right-skewed age distribution',
                'description': "Age column shows right skew (mean=45.8, median=32.0) driven by outlier value 150"
            },
            {
                'severity': 'P3',
                'title': 'Positive: No missing values',
                'description': "All 70 cells (100%) across all 7 columns are filled"
            }
        ],
        'summary': f"Quality assessment complete: score {final_score}/100 ({rating}). "
                   f"1 dataset assessed. Completeness is perfect. Minor issues: 2 duplicate occurrences "
                   f"and 4 outliers detected. Dataset is usable with minor cleanup.",
        'report': report
    }
}

print(f"\n\n=== FINAL JSON OUTPUT ===")
print(json.dumps(output, indent=2))
