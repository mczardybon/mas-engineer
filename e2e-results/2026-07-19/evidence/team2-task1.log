dup_rate = 0.0
dup_deduction = 0.0
if total_rows > 0:
    dup_rate = total_dup_occurrences / total_rows
    if dup_rate > 0.5:
        dup_deduction = 25.0
    else:
        dup_deduction = dup_rate * 2 * 25
    score -= dup_deduction
    deductions.append({
        'dimension': 'duplicates',
        'weight': '25%',
        'duplicate_rate': round(dup_rate * 100, 2),
        'deduction': round(dup_deduction, 2)
    })
print(f"D2 Duplicates: dup_rate={dup_rate:.4f}, deduction={dup_deduction:.2f}, score={score:.2f}")

# Dimension 3: Outliers — weight: 20%
total_outliers = sum(
    a.get('anomalies', {}).get('outliers', {}).get('total_outlier_count', 0)
    for a in merged.values()
)

outlier_rate = 0.0
outlier_deduction = 0.0
if total_rows > 0:
    outlier_rate = total_outliers / (total_rows * max(len(profile_by_file), 1))
    outlier_deduction = min(outlier_rate * 20, 20)
    score -= outlier_deduction
    deductions.append({
        'dimension': 'outliers',
