        'deduction': round(severe_missing_rate * 15, 2)
    })
print(f"D4 Missing: high_missing={high_missing_columns}/{total_columns}, deduction={severe_missing_rate * 15:.2f}, score={score:.2f}")

# Dimension 5: Categorical anomalies — weight: 10%
