    after: def detect_duplicates_csv(rows, fieldnames):
    """STEP 1 — Duplicate Detection (including near-duplicates ignoring key column)"""
    row_tuples = [tuple(row.get(col, '') for col in fieldnames) for row in rows]
    dup_counts = Counter(row_tuples)

    exact_duplicates = []
    for row_tuple, count in dup_counts.items():
        if count > 1:
            indices = [i for i, rt in enumerate(row_tuples) if rt == row_tuple]
            exact_duplicates.append({
                'row_indices': indices[:5],
                'total_occurrences': count,
                'values': dict(zip(fieldnames, row_tuple))
            })

    # Duplicate key detection (first column as key = id)
    key_duplicates = []
    if fieldnames and len(fieldnames) > 0:
        id_col = fieldnames[0]
        key_counts = Counter(row.get(id_col, '') for row in rows)
        key_duplicates = [
            {'key_value': k, 'occurrences': v}
            for k, v in key_counts.items() if v > 1
        ]

    total_dup_occurrences = sum(d['total_occurrences'] for d in exact_duplicates)

    # Near-duplicate detection: ignore first column (id) and check content match
    # This catches rows like (1,Alice,29,...) and (6,Alice,29,...) as near-duplicates
    if fieldnames and len(fieldnames) > 1:
        content_fieldnames = fieldnames[1:]  # skip id column
        content_tuples = [tuple(row.get(col, '') for col in content_fieldnames) for row in rows]
        content_dup_counts = Counter(content_tuples)
        
        near_duplicates = []
        for content_tuple, count in content_dup_counts.items():
            if count > 1:
                indices = [i for i, ct in enumerate(content_tuples) if ct == content_tuple]
                near_duplicates.append({
                    'row_indices': indices[:5],
                    'total_occurrences': count,
                    'values': dict(zip(content_fieldnames, content_tuple)),
                    'note': 'Rows differ only in id column (content-identical)'
                })

        # Merge near-duplicates into exact_duplicates reporting
        for nd in near_duplicates:
            # Check if this is already reported as exact duplicate
            already_reported = False
            for ed in exact_duplicates:
                if set(ed['row_indices']) == set(nd['row_indices']):
                    already_reported = True
                    break
            if not already_reported:
                exact_duplicates.append({
                    'row_indices': nd['row_indices'],
                    'total_occurrences': nd['total_occurrences'],
                    'values': nd['values'],
                    'near_duplicate': True,
                    'note': nd['note']
                })
                total_dup_occurrences += nd['total_occurrences']

    return {
        'exact_duplicate_rows': len(exact_duplicates),
        'exact_duplicate_details': exact_duplicates[:10],
        'duplicate_keys': key_duplicates[:10],
        'total_duplicate_occurrences': total_dup_occurrences
    }


