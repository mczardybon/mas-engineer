    'anomaly_count': total_cat_anomalies,
    'deduction': cat_deduction
})
print(f"D5 Categorical: count={total_cat_anomalies}, deduction={cat_deduction:.2f}, score={score:.2f}")

final_score = max(0, round(score, 2))
print(f"\n=== FINAL SCORE: {final_score} ===")

# ── STEP 3: Quality Rating ──
def get_quality_rating(score):
    if score >= 90: return 'EXCELLENT', 'Data quality is excellent — suitable for analysis'
    elif score >= 75: return 'GOOD', 'Data quality is good — minor issues found'
    elif score >= 50: return 'FAIR', 'Data quality is fair — several issues need attention'
    elif score >= 25: return 'POOR', 'Data quality is poor — significant issues present'
    else: return 'CRITICAL', 'Data quality is critically low — action required before use'

rating, rating_desc = get_quality_rating(final_score)
