            elif 'goose_model' in s:
                errors.append(f'❌ {f}: still has \"goose_model\" instead of \"model\"')
    except yaml.YAMLError as e:
        errors.append(f'❌ {f}: YAML parse error: {e}')
    except Exception as e:
        errors.append(f'❌ {f}: {e}')

print()
if errors:
    for e in errors:
        print(e)
    sys.exit(1)
else:
    print('🎉 All YAML files valid and correctly structured!')
