import csv

# Read messy dataset
with open('messy_dataset.csv', 'r') as f:
    messy = list(csv.DictReader(f))
    
# Read sample dataset
with open('sample_dataset.csv', 'r') as f:
    sample = list(csv.DictReader(f))

print('=== MESSY DATASET ===')
for r in messy:
    print(r)
print()
print('=== SAMPLE DATASET ===')
for r in sample:
    print(r)
print()

# 1. Exact duplicates in messy
print('=== EXACT DUPLICATE ANALYSIS ===')
for i in range(len(messy)):
    for j in range(i+1, len(messy)):
        if messy[i] == messy[j]:
            print(f'Row {i+1} (id={messy[i][\"id\"]}) == Row {j+1} (id={messy[j][\"id\"]}) : {messy[i]}')

# 2. Near duplicates - same name+age+city
print()
print('=== NEAR DUPLICATE ANALYSIS (name+age+city) ===')
for i in range(len(messy)):
    for j in range(i+1, len(messy)):
        a, b = messy[i], messy[j]
        if a['name'] and b['name'] and a['name'] == b['name']:
            if a['age'] and b['age'] and a['age'] == b['age']:
                if a['city'] and b['city'] and a['city'] == b['city']:
                    print(f'Row {i+1} and {j+1}: name={a[\"name\"]}, age={a[\"age\"]}, city={a[\"city\"]}')

# Also check same name
print()
print('=== SAME NAME, DIFFERENT VALUES ===')
from collections import defaultdict
by_name = defaultdict(list)
for i, r in enumerate(messy):
    if r['name']:
        by_name[r['name']].append((i+1, r))
for name, rows in by_name.items():
    if len(rows) > 1:
        print(f'{name}: {rows}')

# 3. Cross-dataset: check sample IDs against messy IDs
print()
print('=== CROSS-DATASET CONSISTENCY ===')
sample_by_id = {r['id']: r for r in sample}
for r in messy:
    mid = r['id']
    if mid in sample_by_id:
        s = sample_by_id[mid]
        issues = []
        if r['name'] and s['name'] and r['name'] != s['name']:
            issues.append(f'name mismatch: messy={r[\"name\"]} vs sample={s[\"name\"]}')
        if r['age'] and s['age'] and r['age'] != s['age']:
            issues.append(f'age mismatch: messy={r[\"age\"]} vs sample={s[\"age\"]}')
        if r['salary'] and s['salary'] and r['salary'] != s['salary']:
            issues.append(f'salary mismatch: messy={r[\"salary\"]} vs sample={s[\"salary\"]}')
        if not r['name'] and s['name']:
            issues.append(f'name is missing in messy (expected \"{s[\"name\"]}\")')
        if not r['age'] and s['age']:
            issues.append(f'age is missing in messy (expected {s[\"age\"]})')
        if not r['salary'] and s['salary']:
            issues.append(f'salary is missing in messy (expected {s[\"salary\"]})')
        if issues:
            print(f'id={mid} ({r.get(\"name\",\"\") or \"empty\"}): {\" | \".join(issues)}')
        else:
            print(f'id={mid} ({r.get(\"name\",\"\") or \"empty\"}): OK')
    else:
        print(f'id={mid} ({r.get(\"name\",\"\") or \"empty\"}): No matching sample ID')

# 4. Check data types
print()
print('=== DATA TYPE ISSUES ===')
for i, r in enumerate(messy):
    row_num = i + 1
    name = r['name'] or '(empty)'
    if r['age']:
        try:
            age = int(r['age'])
            if age > 120:
                print(f'Row {row_num} (id={r[\"id\"]}, {name}): age={r[\"age\"]} is unrealistic (> 120)')
        except:
            print(f'Row {row_num} (id={r[\"id\"]}, {name}): age=\"{r[\"age\"]}\" is not a valid integer')
    if r['salary']:
        try:
            sal = int(r['salary'])
        except:
            print(f'Row {row_num} (id={r[\"id\"]}, {name}): salary=\"{r[\"salary\"]}\" is not a valid integer')

# 5. Missing values
print()
print('=== MISSING VALUES ===')
for i, r in enumerate(messy):
    row_num = i + 1
    missing = [k for k, v in r.items() if not v]
    if missing:
        print(f'Row {row_num} (id={r[\"id\"]}): missing fields: {missing}')

# 6. Total empty row
print()
print('=== COMPLETELY EMPTY ROW ===')
for i, r in enumerate(messy):
    if all(not v for v in r.values()):
        print(f'Row {i+1} (id={r[\"id\"]}): COMPLETELY EMPTY')
