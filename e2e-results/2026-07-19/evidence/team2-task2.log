            elif missing >= n_rows * 0.15:
                severity = "Medium"
            else:
                severity = "Low"
            print(f"  Severity: {severity}")
        else:
            print(f"  Severity: None")
    
    # Overall completeness
    overall_completeness = ((total_cells - total_missing) / total_cells) * 100
    print("\n" + "=" * 70)
    print(f"--- OVERALL DATASET COMPLETENESS ---")
    print(f"Total cells: {total_cells}")
    print(f"Total missing cells: {total_missing}")
    print(f"Overall completeness: {overall_completeness:.1f}%")
    
    # Row-by-row analysis
    print("\n" + "=" * 70)
    print("--- ROW-BY-ROW COMPLETENESS ---")
    for i, row in enumerate(rows, 1):
        filled = 0
        empty_fields = []
        for col in columns:
            val = row.get(col, '')
            if val is None or val.strip() == '':
                empty_fields.append(col)
            else:
                filled += 1
        pct = (filled / n_cols) * 100
        status = "COMPLETE" if filled == n_cols else "PARTIAL" if filled > 0 else "EMPTY"
        print(f"Row {i}: {filled}/{n_cols} filled ({pct:.0f}%) [{status}]")
        if empty_fields:
            print(f"       Missing fields: {', '.join(empty_fields)}")
    
    # Pattern analysis
    print("\n" + "=" * 70)
    print("--- PATTERN ANALYSIS ---")
    
    # Check if row 7 is entirely empty
    row7_filled = sum(1 for col in columns if rows[6].get(col, '').strip() != '')
    print(f"\n1. Row 7 (last row): {row7_filled}/{n_cols} fields filled — {'Nearly empty row, likely a scraper artifact or corrupt data' if row7_filled <= 1 else 'Partially filled'}")
    
    # Check for duplicates
    seen = {}
    for i, row in enumerate(rows, 1):
        vals = tuple(row.get(c, '').strip() for c in columns)
        if vals in seen:
            print(f"2. Row {i} is a duplicate of row {seen[vals]}")
        seen[vals] = i
    
    if len(set(seen.keys())) == len(rows):
        print("2. No exact duplicate rows found")
    
    # Missingness distribution
    print("3. Missingness pattern:")
    print(f"   - {n_rows - len([r for r in rows if all(v.strip() for v in r.values())])} rows have at least one missing value")
    complete_rows = sum(1 for row in rows if all(v.strip() for v in row.values()))
    print(f"   - {complete_rows} rows are fully complete")
    
    # Check if missingness is concentrated in specific rows or columns
    missing_by_col = sorted([(col, cnt) for col, (cnt, _) in col_missing.items()], key=lambda x: -x[1])
    if missing_by_col[0][1] > 0:
        print(f"   - Column '{missing_by_col[0][0]}' has the most missing values ({missing_by_col[0][1]})")
    
    # Check if row 7 alone accounts for most missingness
    row7_missing = n_cols - row7_filled
    if row7_missing > 0:
        pct_from_row7 = (row7_missing / total_missing) * 100
        print(f"   - Row 7 alone accounts for {row7_missing}/{total_missing} ({pct_from_row7:.0f}%) of all missing values")
    
    print("\n4. Verdict on missingness pattern:")
    if row7_missing / total_missing > 0.5:
        print("   ⚠ SYSTEMATIC — Missingness is heavily concentrated in one row (row 7), suggesting a structural issue")
    else:
        print("   ⚡ MIXED — Some systematic (row 7 is nearly empty) and some random/sporadic missing values")
    
    print("\n" + "=" * 70)
    print("--- SEVERITY SUMMARY ---")
    for col in columns:
        cnt, idxs = col_missing[col]
        if cnt == 0:
            sev = "None"
        elif cnt >= n_rows * 0.5:
            sev = "Critical"
        elif cnt >= n_rows * 0.25:
            sev = "High"
        elif cnt >= n_rows * 0.15:
            sev = "Medium"
        else:
            sev = "Low"
        print(f"  {col}: {sev} ({cnt}/{n_rows} missing)")

