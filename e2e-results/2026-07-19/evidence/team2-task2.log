import csv

# Check for data quality issues beyond just missing values
with open("messy_dataset.csv") as f:
    reader = csv.DictReader(f)
    rows = list(reader)
    columns = reader.fieldnames

print("--- DATA QUALITY ANOMALIES ---")

# Check for anomalous age values
for i, row in enumerate(rows, 1):
    age = row.get('age', '').strip()
    if age:
        try:
            age_int = int(age)
            if age_int > 120 or age_int < 0:
                print(f"Row {i}: age={age} is out of plausible range (0-120)")
        except:
            print(f"Row {i}: age='{age}' is not a valid number")

# Check for salary anomalies
for i, row in enumerate(rows, 1):
    sal = row.get('salary', '').strip()
    if sal:
        try:
            sal_int = int(sal)
            if sal_int < 0 or sal_int > 500000:
                print(f"Row {i}: salary={sal} is out of plausible range")
        except:
            print(f"Row {i}: salary='{sal}' is not a valid number")

# Check for exact/approximate duplicates
print("\n--- DUPLICATE / NEAR-DUPLICATE ANALYSIS ---")
profiles = []
for i, row in enumerate(rows, 1):
    name = row.get('name', '').strip()
    city = row.get('city', '').strip()
    age = row.get('age', '').strip()
    salary = row.get('salary', '').strip()
    profiles.append((i, name, age, salary, city))

# Compare rows
for i in range(len(profiles)):
    for j in range(i+1, len(profiles)):
        r1 = profiles[i]
        r2 = profiles[j]
        name_match = r1[1] and r2[1] and r1[1] == r2[1]
        city_match = r1[4] and r2[4] and r1[4] == r2[4]
        salary_match = r1[3] and r2[3] and r1[3] == r2[3]
        age_match = r1[2] and r2[2] and r1[2] == r2[2]
        
        matches = sum([name_match, city_match, salary_match, age_match])
        if matches >= 3:
            print(f"Row {r1[0]} and Row {r2[0]}: {matches}/4 fields match — potential duplicate")

# Cross-reference with sample dataset
print("\n--- CROSS-REFERENCE WITH SAMPLE DATASET ---")
with open("sample_dataset.csv") as f:
    sample_reader = csv.DictReader(f)
    sample_rows = list(sample_reader)

print(f"Sample dataset has {len(sample_rows)} rows and columns: {list(sample_rows[0].keys())}")
print(f"Messy dataset has {len(rows)} rows and columns: {columns}")
print(f"Common columns: id, name, age, salary")
print(f"Sample has extra columns: department, join_date, email")
print(f"Messy has extra column: city")

# Check if messy data values exist in sample
sample_names = {r['name'] for r in sample_rows if r['name'].strip()}
sample_cities = set()  # sample doesn't have city column
print(f"\nNames in sample: {sample_names}")
print(f"Names in messy: {set(r['name'].strip() for r in rows if r['name'].strip())}")
print(f"Names shared: {sample_names & set(r['name'].strip() for r in rows if r['name'].strip())}")
