print(f'Mean: {statistics.mean(salaries):.1f}')
print(f'Median: {statistics.median(salaries)}')
q1s = sorted(salaries)[1]
q3s = sorted(salaries)[3]
iqrs = q3s - q1s
print(f'Q1={q1s}, Q3={q3s}, IQR={iqrs}')
print(f'Lower fence={q1s-1.5*iqrs}, Upper fence={q3s+1.5*iqrs}')
print(f'Outliers: {[s for s in salaries if s < q1s-1.5*iqrs or s > q3s+1.5*iqrs]}')
print()
print('=== SAMPLE REFERENCE (ages) ===')
sample_ages = [29,45,34,28,150,29,33,27,52,31]
print(f'Sample ages: {sample_ages}')
print(f'Sample mean age: {statistics.mean(sample_ages):.1f}')
print(f'Sample salary ref: [75000,92000,68000,72000,50000,75000,71000,65000,110000,73000]')
