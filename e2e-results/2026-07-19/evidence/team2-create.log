version: 1.0.0
configs:
  mas-self:
    type: main-agent
    version: 2.0.0
    first_session:
      steps:
      - 'load(source: ''sub_mas-system-knowledge'')'
      - cat .mas-mode → work_on = mas | framework | <project>  (R14)
      - 'IF work_on == "mas": cat mas-engineer/.state/workflows.yaml → restrictions,
        task_workflows, recovery, enforcement, signals, token_budgets'
      - 'IF work_on != "mas": MAS-Configuration will NICHT loaded (R13) — weiter msg
        Frage'
      - cat .state/knowledge/{thema}.md (at Bemay)
      then: 'Question: What should I do?'
    paths:
      mas:
        source_dir: '{workspace}/mas-engineer'
        install_dir: ~/.config/goose/recipe
        tools_install: ~/.config/goose/recipe/mas-engineer-tools
        state_dir: '{workspace}/mas-engineer/.state'
      projekt:
        work_dir: '{workspace} (dynamic, dynamically set by caller)'
      mode:
        current: mas
        current_via: cat {workspace}/mas-engineer/.mas-mode || cat ~/.config/goose/.mas-mode
        modi:
        - mas
        - framework
        - generic
    restrictions:
      r01_confirmation:
        level: extreme
        description: 'Before EVERY write/edit/shell: check if confirmation needed'
        details:
        - 'IF action YAML/Code changes: SHOW Plan + WAIT auf ✅'
        - 'IF action only reads/analyzes: NO confirmation'
      r02_bestand:
        level: extreme
        description: INVENTORY before new build — Check ob Tool/Agent/Function already
          exists
      r03_reserved:
        level: info
        description: Reserved for future use
      r04_general_improver:
        level: extreme
        description: NEVER general-improver.yaml edit
      r05_auto_commsg:
        level: extreme
        description: CHECKPOINT BEFORE change — 1. Checkpoint, 2. Change, 3. commsg
          (tightened)
        details:
        - STEP 1 — CHECKPOINT (BEFORE the change): null
        - '  → mkdir -p .state/checkpoints/{ts}/ && cp -r recipe/ tools/ docs/ .state/workflows.yaml
          .state/change.json .state/knowledge/ → .state/checkpoints/{ts}/'
        - '  → SHOW: ''✅ Checkpoint {ts} — if something goes wrong'''
        - STEP 2 — CHANGE DURCHEXECUTEN: null
        - '  → edit/write/shell according to R01 + R10'
        - STEP 3 — COMMIT (NACH der Change): null
        - '  → git add -A && git commsg -m ''[MAS] ...'''
        - '  → change.json + {timestamp, action, description} — NEVER emptye description'
        - '  → todo.todoWrite(''✅ ...'')'
        - ORDER IS MANDATORY — on violation: ROLLBACK
      r06_sub_agent:
        level: stark
        description: Sub-agent = ONLY analysis — execute shell yourself
      r07_signal:
        level: normal
        description: CP_DONE after checkpoint sent
      r08_token:
        level: normal
        description: General-Improver max 50K Tokens — otherwise ask user
      r09_domain:
        level: extreme
        description: MODE-DOMAIN-COUPLING
        details:
        - MAS importiert NEVER framework-Components (BLOCKED)
        - framework weiss NOTHING from MAS (BLOCKED)
        - 'Beim Reading/: .mas-mode checkn (MAS vs FRAMEWORK)'
      r10_coronashield:
        level: extreme
        description: EVERY YAML must be validated via sub_mas-recovery-immune CHECK_YAML
          before storing
      r11_si_rate_limsg:
        level: extreme
        description: Max 1 General-Improver every 6 hours
      r12_work_mas_entkopplung:
        level: extreme
        description: NO dependency between work/ and MAS. MAS lives in ~/.config/goose/.state/mas/
        details:
        - MAS-State liegt in ~/.config/goose/.state/mas/ (not in work/.../)
        - work/ can deleted will without MAS zu corrupt
        - BEIM START: Check ob work/ a Project ist — NICHT ob it MAS ist
        - work/ contains NOE MAS-statesfileen (.state/, checkpoints/, .backups/ —
          bis auf .mas-mode)
        - MAS-install.sh und update.sh copy State NACH ~/.config/goose/.state/mas/
      r13_newes_projekt_ignore:
        level: extreme
        description: Newit Project = MAS-Configuration ignore (prompt_1)
        details:
