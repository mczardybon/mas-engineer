        -name 'config.yaml' -not -path '*_framework*'
      timeout: 30
      on_error: continue
    - id: analyze_recipe
      action: shell
      cmd: for f in $(find {workspace} -name '*.yaml' -not -path '*_framework*' |
        head -50); do echo "=== $f ==="; grep 'title:' "$f" 2>/dev/null; done
      depends_on:
      - discover_structure
      timeout: 60
      on_error: continue
    - id: classify
