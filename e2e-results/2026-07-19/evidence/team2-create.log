import pandas as pd, json, sys
fp = '{file_path}'
if fp.endswith('.csv'):
    df = pd.read_csv(fp, nrows={sample_size})
elif fp.endswith('.json'):
    df = pd.read_json(fp)
elif fp.endswith('.jsonl'):
    df = pd.read_json(fp, lines=True)
else:
    print('ERROR: Unsupported format')
    sys.exit(1)
profile = {{
    'rows': len(df),
    'columns': len(df.columns),
    'column_names': list(df.columns),
    'missing_summary': {{
        'total_cells': int(df.size),
        'total_missing': int(df.isnull().sum().sum()),
        'missing_pct': float(round(df.isnull().sum().sum() / df.size * 100, 2))
    }}
}}
print(json.dumps(profile, indent=2))
"
        timeout: 60
      - id: analyze_types
        action: shell
        cmd: python3 -c "
import pandas as pd, json
fp = '{file_path}'
if fp.endswith('.csv'):
    df = pd.read_csv(fp, nrows=1000)
elif fp.endswith('.json'):
    df = pd.read_json(fp)
else:
    df = pd.read_json(fp, lines=True)
col_types = []
for col in df.columns:
    info = {{'name': col, 'dtype': str(df[col].dtype)}}
    if pd.api.types.is_numeric_dtype(df[col]):
        info['detected_type'] = 'numeric'
        info['stats'] = {{
            'min': float(df[col].min()) if df[col].notna().any() else None,
            'max': float(df[col].max()) if df[col].notna().any() else None,
            'mean': float(round(df[col].mean(), 2)) if df[col].notna().any() else None,
            'median': float(round(df[col].median(), 2)) if df[col].notna().any() else None,
            'unique_values': int(df[col].nunique())
        }}
    elif pd.api.types.is_object_dtype(df[col]):
        info['detected_type'] = 'categorical'
        info['stats'] = {{
            'unique_values': int(df[col].nunique()),
            'top_values': df[col].value_counts().head(5).to_dict()
        }}
    else:
        info['detected_type'] = 'other'
    info['missing'] = int(df[col].isnull().sum())
    info['missing_pct'] = float(round(df[col].isnull().sum() / len(df) * 100, 2))
    col_types.append(info)
print(json.dumps({{'column_details': col_types}}, indent=2))
"
        timeout: 60
