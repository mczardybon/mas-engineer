  <script>
    async function refresh() {
      try {
        const r = await fetch('data.json');
        const d = await r.json();
        document.getElementById('total').textContent = d.dispatch?.total || 0;
        document.getElementById('running').textContent = d.dispatch?.active || 0;
        document.getElementById('done').textContent = d.dispatch?.done || 0;
        document.getElementById('errors').textContent = d.dispatch?.failed || 0;
        document.getElementById('workspace').textContent = d.workspace || '';
      } catch (e) {
        console.error('refresh failed', e);
      }
    }
    refresh();
    setInterval(refresh, 5000);
  </script>
</body>
</html>


