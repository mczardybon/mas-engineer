    content: """Tests for sales-team agent YAML syntax."""

import yaml
import json
from pathlib import Path

BASE = Path("/tmp/sales-team")

REQUIRED_FIELDS = ["name", "version", "title", "description", "prompt", "instructions", "settings"]
SETTINGS_FIELDS = ["timeout", "max_steps"]
ORCHESTRATOR_REQUIRED = ["name", "version", "title", "description", "prompt", "instructions", "sub_recipes", "settings"]
SUB_RECIPE_FIELDS = ["name", "description", "path"]

def check_yaml(path, required_fields, extra_checks=None):
    """Check a YAML file exists and has required fields."""
    path = Path(path)
    assert path.exists(), f"Missing: {path}"
    assert path.stat().st_size > 0, f"Empty: {path}"
    with open(path) as f:
        data = yaml.safe_load(f)
    assert data is not None, f"Invalid YAML: {path}"
    for field in required_fields:
        assert field in data, f"Missing field '{field}' in {path}"
    if extra_checks:
        extra_checks(data, path)
    return True


def test_orchestrator():
    """Test sales-team orchestrator YAML."""
    path = BASE / "recipe" / "sales-team.yaml"
    check_yaml(path, ORCHESTRATOR_REQUIRED)
    with open(path) as f:
        data = yaml.safe_load(f)
    # Check sub_recipes
    for sr in data["sub_recipes"]:
        for field in SUB_RECIPE_FIELDS:
            assert field in sr, f"Missing sub_recipe field '{field}' in {path}"
        sub_path = Path(path).parent / sr["path"]
        assert sub_path.exists(), f"Sub-recipe not found: {sub_path}"
    # Check name
    assert data["name"] == "sales-team"


def test_lead_enricher():
    path = BASE / "recipe" / "sub" / "lead-enricher.yaml"
    check_yaml(path, REQUIRED_FIELDS)
    with open(path) as f:
        data = yaml.safe_load(f)
    assert data["name"] == "sub_sales-lead-enricher"


def test_email_composer():
    path = BASE / "recipe" / "sub" / "email-composer.yaml"
    check_yaml(path, REQUIRED_FIELDS)
    with open(path) as f:
        data = yaml.safe_load(f)
    assert data["name"] == "sub_sales-email-composer"


def test_follow_up_scheduler():
    path = BASE / "recipe" / "sub" / "follow-up-scheduler.yaml"
    check_yaml(path, REQUIRED_FIELDS)
    with open(path) as f:
        data = yaml.safe_load(f)
    assert data["name"] == "sub_sales-follow-up-scheduler"


def test_deal_closer():
    path = BASE / "recipe" / "sub" / "deal-closer.yaml"
    check_yaml(path, REQUIRED_FIELDS)
    with open(path) as f:
        data = yaml.safe_load(f)
    assert data["name"] == "sub_sales-deal-closer"


def test_data_json():
    path = BASE / ".mas" / "dashboards" / "data.json"
    assert path.exists(), f"Missing: {path}"
    assert path.stat().st_size > 0, f"Empty: {path}"
    with open(path) as f:
        data = json.load(f)
    assert "agents" in data
    assert "dispatch" in data
    assert "health" in data
    assert len(data["agents"]["scores"]) == 5


def test_all_settings():
    """Check that all sub-agent YAMLs have correct settings fields."""
    for sub in ["lead-enricher", "email-composer", "follow-up-scheduler", "deal-closer"]:
        path = BASE / "recipe" / "sub" / f"{sub}.yaml"
        with open(path) as f:
            data = yaml.safe_load(f)
        settings = data.get("settings", {})
        for field in SETTINGS_FIELDS:
            assert field in settings, f"Missing settings field '{field}' in {path}"


