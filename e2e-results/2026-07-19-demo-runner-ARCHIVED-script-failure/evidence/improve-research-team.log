    content: """Test: YAML-Syntax allr Agenten + orchestrator."""
import os
import yaml

PROJECT_DIR = os.path.join(os.path.dirname(__file__), "..")
SUBS_DIR = os.path.join(PROJECT_DIR, "recipe", "sub")
ORCHESTRATOR_PATH = os.path.join(PROJECT_DIR, "recipe", "research-team.yaml")

REQUIRED_FIELDS = {"name", "version", "title", "description", "instructions", "prompt", "settings"}
SETTINGS_FIELDS = {"timeout", "max_steps"}


def _validate_agent_yaml(path: str):
    """Validate YAML syntax and required fields for a single agent file."""
    with open(path) as fh:
        data = yaml.safe_load(fh)

    assert isinstance(data, dict), f"{path}: expected dict root, got {type(data)}"

    # Check required fields
    for field in REQUIRED_FIELDS:
        assert field in data, f"{path}: missing required field '{field}'"

    # Check settings sub-fields
    settings = data.get("settings", {})
    assert isinstance(settings, dict), f"{path}: 'settings' must be a dict"
    for field in SETTINGS_FIELDS:
        assert field in settings, f"{path}: settings missing '{field}'"
        assert isinstance(settings[field], int), f"{path}: settings.{field} must be int"

    # Check that instructions is present and non-empty
    instructions = data.get("instructions", "")
    assert instructions and len(instructions) > 50, f"{path}: 'instructions' is too short or empty"

    # Check that prompt is present and non-empty
    prompt = data.get("prompt", "")
    assert prompt and len(prompt) > 20, f"{path}: 'prompt' is too short or empty"

    return data


def test_all_agent_yamls():
    """Checks whether all Sub-Agent-YAMLs are valid and have required fields."""
    if not os.path.exists(SUBS_DIR):
        return  # No agents yet
    for f in sorted(os.listdir(SUBS_DIR)):
        if f.endswith(".yaml"):
            path = os.path.join(SUBS_DIR, f)
            data = _validate_agent_yaml(path)
            print(f"✅ {f} — valid (name={data.get('name')}, version={data.get('version')})")


def test_orchestrator_yaml():
    """Checks whether the orchestrator YAML is valid and has required fields."""
    assert os.path.exists(ORCHESTRATOR_PATH), f"Orchestrator not found: {ORCHESTRATOR_PATH}"
    data = _validate_agent_yaml(ORCHESTRATOR_PATH)
    print(f"✅ orchestrator/research-team.yaml — valid (name={data.get('name')}, version={data.get('version')})")

    # Check that the orchestrator references valid sub-recipes
    sub_recipes = data.get("sub_recipes", [])
    assert len(sub_recipes) > 0, "orchestrator: must define at least one sub_recipe"
    for sub in sub_recipes:
        assert "name" in sub, f"orchestrator: sub_recipe missing 'name'"
        assert "path" in sub, f"orchestrator: sub_recipe '{sub.get('name')}' missing 'path'"
        sub_path = os.path.join(os.path.dirname(ORCHESTRATOR_PATH), sub["path"])
        assert os.path.exists(sub_path), f"orchestrator: sub_recipe '{sub['name']}' path not found: {sub_path}"
        print(f"   ✅ sub_recipe '{sub['name']}' → {sub['path']} (exists)")


