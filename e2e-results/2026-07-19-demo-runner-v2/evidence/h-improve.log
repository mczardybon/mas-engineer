    path: sub/source-verifier.yaml
    description: "✅ MANDATORY quality gate — filters and verifies sources"
  - name: Fact Extractor
    path: sub/fact-extractor.yaml
    description: "📊 Extracts structured facts from verified sources"
  - name: Synthesizer
    path: sub/synthesizer.yaml
    description: "📝 Combines facts into a coherent answer with citations"
