            with open(test_file, "w") as f:
                f.write('''"""Test: YAML-Syntax allr Agenten."""
import os
import yaml

SUBS_DIR = os.path.join(os.path.dirname(__file__), "..", "recipe", "sub")


def test_all_agent_yamls():
