except Exception as e:
    results.append(('Test 11: json.load(data.json)', 'FAIL', str(e)))
    print(f'  ❌ Test 11: FAIL - {e}')

# Test 12: data.json has 12 required keys
required = ['version','timestamp','workspace','mode','project_name','agents','changes','improvement','dispatch','build','health','health_trend']
missing = [k for k in required if k not in d]
if not missing:
    results.append(('Test 12: data.json has 12 required keys', 'PASS', f'all {len(required)} keys present'))
    print(f'  ✅ Test 12: PASS - all 12 keys present')
else:
    results.append(('Test 12: data.json has 12 required keys', 'FAIL', f'missing: {missing}'))
    print(f'  ❌ Test 12: FAIL - missing keys: {missing}')

# Test 13: agents.total = 5
if d['agents']['total'] == 5:
    results.append(('Test 13: agents.total = 5', 'PASS', f'got {d[\"agents\"][\"total\"]}'))
    print(f'  ✅ Test 13: PASS - agents.total = 5')
else:
    results.append(('Test 13: agents.total = 5', 'FAIL', f'got {d[\"agents\"][\"total\"]}'))
    print(f'  ❌ Test 13: FAIL - expected 5, got {d[\"agents\"][\"total\"]}')

# Test 14: project_name = research-team
if d['project_name'] == 'research-team':
    results.append(('Test 14: project_name = research-team', 'PASS', f'got \"{d[\"project_name\"]}\"'))
    print(f'  ✅ Test 14: PASS - project_name = \"research-team\"')
else:
    results.append(('Test 14: project_name = research-team', 'FAIL', f'got \"{d[\"project_name\"]}\"'))
    print(f'  ❌ Test 14: FAIL - expected \"research-team\"')

print()
print('=' * 60)
print('PYTHON TESTS SUMMARY (Tests 6-14)')
passed = sum(1 for r in results if r[1] == 'PASS')
failed = sum(1 for r in results if r[1] == 'FAIL')
for r in results:
    status_icon = '✅' if r[1] == 'PASS' else '❌'
    print(f'  {status_icon} {r[0]}: {r[1]} ({r[2]})')
print(f'Total: {passed} PASS, {failed} FAIL')
"


